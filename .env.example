# Convex — run `pnpm convex:dev:once` to auto-fill deployment URL in apps/web/.env.local
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Demo sign-in (Next.js — hand out to users)
DEMO_EMAIL=admin@gmail.com
DEMO_PASSWORD=pass1234
NEXT_PUBLIC_DEMO_EMAIL=admin@gmail.com
NEXT_PUBLIC_DEMO_PASSWORD=pass1234

# Convex Auth (set in Convex dashboard — generate with: node scripts/generate-auth-keys.mjs)
# JWT_PRIVATE_KEY=
# JWKS=
# SITE_URL=http://localhost:3000

# Optional: sync action API keys from .env to Convex:
#   pnpm convex:env
# Push backend after changes:
#   pnpm convex:push

# Optional: Hermes harness (NOT used for audit LLM)
HERMES_API_URL=
# Optional side feature — Telegram relay only; web UI is primary
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=
# Optional harness-side chat via AI Gateway (in ~/.hermes/.env):
# ANTHROPIC_BASE_URL=https://ai-gateway.vercel.sh
# AI_GATEWAY_API_KEY=

# AI Gateway — all audit LLM (Convex actions)
AI_GATEWAY_API_KEY=
PAPERFORK_LLM_MODEL=openai/gpt-5.4
PAPERFORK_LLM_GROQ_MODEL=groq/llama-3.3-70b-versatile
GROQ_API_KEY=
PAPERFORK_GROQ_MODEL=llama-3.3-70b-versatile
# PAPERFORK_LLM_MOCK=1

# Literature (arXiv public API — no key required)
ARXIV_API_BASE=https://export.arxiv.org/api/query

# Web agent (Linkup)
LINKUP_API_KEY=
LINKUP_PROMO=HERMES

# GitHub
GITHUB_TOKEN=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Cloudflare (optional CLI deploy)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# App
NEXT_PUBLIC_APP_URL=https://www.getkarpathy.com
NEXT_PUBLIC_CONTACT_EMAIL=paperfork@getkarpathy.com
APP_CONTACT_EMAIL=paperfork@getkarpathy.com

# Ship
CRON_NOTIFY_WEBHOOK=
EVAL_FIXTURE_REPO=
PAPERFORK_WEBHOOK_SECRET=
